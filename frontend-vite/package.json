{
  "name": "paper-labeler",
  "productName": "Paper Labeler",
  "description": "试卷题目标注工具",
  "repository": {
    "type": "git",
    "url": "https://github.com/laurens1995s/paper_labeler.git"
  },
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n fe,be -c cyan,green \"vite\" \"cd .. && python backend/main.py\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "smoke": "node tests/smoke.mjs",
    "e2e:api": "node tests/api-e2e.mjs",
    "electron:dev": "vite build && electron .",
    "electron:watch": "node electron/watch.cjs",
    "electron:build": "vue-tsc -b && vite build && electron-builder --win nsis --publish never",
    "electron:release": "vue-tsc -b && vite build && electron-builder --win nsis --publish always",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "publish": [
      {
        "provider": "github",
        "owner": "laurensZero",
        "repo": "paper_labeler"
      }
    ],
    "appId": "com.paper-labeler.app",
    "productName": "Paper Labeler",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png",
      "installerHeaderIcon": "build/icon.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Paper Labeler"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "dist",
        "to": "frontend-vite/dist"
      }
    ]
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "electron-updater": "^6.8.9",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.5",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.0",
    "concurrently": "^10.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.8"
  }
}
